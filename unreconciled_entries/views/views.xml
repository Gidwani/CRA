<odoo>
  <data>

    <record id="action_reconciled_entries_tree_view" model="ir.actions.act_window">
            <field name="name">Unreconciled Entries</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">account.move.line</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('full_reconcile_id', '=', False), ('balance', '!=', 0), ('account_id.reconcile', '=', True)]</field>
            <field name="view_id" ref="account.view_move_line_tree_grouped"/>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                No Reasons Found. Let's Create One!
              </p>
            </field>
    </record>

    <menuitem
            id="menu_action_unreconciled_entries"
            name="Unreconciled"
            action="action_reconciled_entries_tree_view"
            parent="account.menu_finance_entries_actions"
            sequence="60"
            />

  </data>
</odoo>